# =============================================================================
# TEMPLATE DE VARIÁVEIS DE AMBIENTE
# =============================================================================
# 1. Copie para .env: cp .env.example .env
# 2. Preencha os valores. NUNCA commite o .env (está no .gitignore)
# 3. Para deploy: use GitHub Secrets (Settings > Secrets and variables > Actions)
# =============================================================================

# Redis (pode ser IP privado se estiver em outro servidor)
REDIS_HOST=
REDIS_PORT=6379
REDIS_QUEUE_NAME=mensagens_fila

# MySQL - banco em outro servidor: use IP privado em MYSQL_HOST
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=ai_agent_database

# API - chave compartilhada com o Lambda (opcional)
API_KEY=
